<?xml version="1.0" encoding="UTF-8"?>
<architecture-diagram name="Elysian Trading System Architecture" version="1.0" date="2026-03-06">
    <metadata>
        <description>
            Comprehensive architecture diagram for the Elysian automated trading system.
            Shows component relationships, data flows, and system layers.
        </description>
        <author>GitHub Copilot</author>
        <language>Python</language>
        <frameworks>
            <framework>asyncio</framework>
            <framework>websockets</framework>
            <framework>peewee</framework>
            <framework>pandas</framework>
            <framework>redis</framework>
        </frameworks>
    </metadata>

    <!-- System Layers -->
    <layers>
        <layer id="entry-point" name="Entry Point Layer" type="orchestration">
            <description>Main application entry point and orchestration</description>
            <components>
                <component id="strategy-runner" name="StrategyRunner" file="elysian_core/run_strategy.py">
                    <class name="StrategyRunner">
                        <description>Main orchestrator class that manages all trading components</description>
                        <methods>
                            <method name="__init__" description="Initialize with config files"/>
                            <method name="run" description="Start all trading components"/>
                            <method name="_setup_config" description="Load YAML/JSON configs"/>
                            <method name="_setup_data_feeds" description="Initialize exchange feeds"/>
                            <method name="setup_binance_feeds" description="Setup Binance multiplex feeds"/>
                            <method name="setup_aster_feeds" description="Setup Aster DEX multiplex feeds"/>
                        </methods>
                        <attributes>
                            <attribute name="config" type="dict" description="YAML configuration"/>
                            <attribute name="config_json" type="dict" description="JSON configuration"/>
                            <attribute name="binance_kline_manager" type="BinanceKlineClientManager"/>
                            <attribute name="binance_ob_manager" type="BinanceOrderBookClientManager"/>
                            <attribute name="aster_kline_manager" type="AsterKlineClientManager"/>
                            <attribute name="aster_ob_manager" type="AsterOrderBookClientManager"/>
                            <attribute name="data_feed" type="dict" description="Active data feeds"/>
                        </attributes>
                    </class>
                </component>
            </components>
        </layer>

        <layer id="market-data" name="Market Data Layer" type="data-acquisition">
            <description>Real-time market data feeds from multiple exchanges</description>
            <components>
                <component id="base-connector" name="AbstractDataFeed" file="elysian_core/connectors/base.py">
                    <class name="AbstractDataFeed" type="abstract">
                        <description>Base class for all exchange data feeds</description>
                        <methods>
                            <method name="executed_buy_price" description="Calculate VWAP for buy orders"/>
                            <method name="executed_sell_price" description="Calculate VWAP for sell orders"/>
                            <method name="update_current_stats" description="Update volatility and statistics"/>
                            <method name="save_to_csv" description="Persist data to CSV"/>
                        </methods>
                        <attributes>
                            <attribute name="_name" type="str" description="Feed identifier"/>
                            <attribute name="_interval" type="str" description="Update interval"/>
                            <attribute name="_data" type="OrderBook" description="Latest order book"/>
                            <attribute name="_vol" type="float" description="Rolling volatility"/>
                            <attribute name="_historical" type="deque" description="Price history"/>
                            <attribute name="save_data" type="bool" description="Enable data persistence"/>
                        </attributes>
                    </class>
                </component>

                <component id="binance-connector" name="BinanceExchange" file="elysian_core/connectors/BinanceExchange.py">
                    <description>Binance exchange integration with multiplex WebSocket feeds</description>
                    <classes>
                        <class name="BinanceKlineClientManager">
                            <description>Shared WebSocket client for multiplex kline streams</description>
                            <methods>
                                <method name="start" description="Initialize AsyncClient and SocketManager"/>
                                <method name="stop" description="Cleanup connections"/>
                                <method name="register_feed" description="Add feed to multiplex stream"/>
                                <method name="run_multiplex_feeds" description="Start reader and worker pool"/>
                                <method name="_reader_coroutine" description="Network message reader"/>
                                <method name="_worker_coroutine" description="Message processor"/>
                            </methods>
                        </class>
                        <class name="BinanceOrderBookClientManager">
                            <description>Shared WebSocket client for multiplex orderbook streams</description>
                        </class>
                        <class name="BinanceKlineFeed" inherits="AbstractDataFeed">
                            <description>Real-time kline data feed for single symbol</description>
                            <methods>
                                <method name="create_new" description="Initialize with symbol and interval"/>
                                <method name="_process_kline_event" description="Parse Binance kline message"/>
                            </methods>
                        </class>
                        <class name="BinanceOrderBookFeed" inherits="AbstractDataFeed">
                            <description>Real-time orderbook feed for single symbol</description>
                            <methods>
                                <method name="get_initial_snapshot" description="Fetch REST snapshot"/>
                                <method name="_process_depth_event" description="Parse depth update"/>
                            </methods>
                        </class>
                        <class name="BinanceSpotExchange">
                            <description>Authenticated Binance client for trading operations</description>
                            <methods>
                                <method name="initialize" description="Setup authenticated client"/>
                                <method name="place_market_order" description="Execute market orders"/>
                                <method name="place_limit_order" description="Execute limit orders"/>
                                <method name="cancel_order" description="Cancel active orders"/>
                                <method name="refresh_balances" description="Update account balances"/>
                                <method name="get_open_orders" description="Fetch current orders"/>
                            </methods>
                        </class>
                    </classes>
                    <globals>
                        <global name="binance_spot_kline_client_manager" type="BinanceKlineClientManager"/>
                        <global name="binance_spot_ob_client_manager" type="BinanceOrderBookClientManager"/>
                    </globals>
                </component>

                <component id="aster-connector" name="AsterExchange" file="elysian_core/connectors/AsterExchange.py">
                    <description>Aster DEX integration with multiplex WebSocket feeds</description>
                    <classes>
                        <class name="AsterKlineClientManager">
                            <description>Shared WebSocket client for multiplex kline streams</description>
                            <methods>
                                <method name="start" description="Initialize WebSocket connection"/>
                                <method name="stop" description="Cleanup connections"/>
                                <method name="register_feed" description="Add feed to multiplex stream"/>
                                <method name="run_multiplex_feeds" description="Start reader and worker pool"/>
                                <method name="_reader_coroutine" description="Network message reader"/>
                                <method name="_worker_coroutine" description="Message processor"/>
                            </methods>
                        </class>
                        <class name="AsterOrderBookClientManager">
                            <description>Shared WebSocket client for multiplex orderbook streams</description>
                        </class>
                        <class name="AsterKlineFeed" inherits="AbstractDataFeed">
                            <description>Real-time kline data feed for single symbol</description>
                            <methods>
                                <method name="create_new" description="Initialize with symbol and interval"/>
                                <method name="_process_kline_event" description="Parse Aster kline message"/>
                            </methods>
                        </class>
                        <class name="AsterOrderBookFeed" inherits="AbstractDataFeed">
                            <description>Real-time orderbook feed for single symbol</description>
                            <methods>
                                <method name="get_initial_snapshot" description="Fetch REST snapshot"/>
                                <method name="_process_depth_event" description="Parse depth update"/>
                            </methods>
                        </class>
                    </classes>
                    <globals>
                        <global name="aster_spot_kline_client_manager" type="AsterKlineClientManager"/>
                        <global name="aster_spot_ob_client_manager" type="AsterOrderBookClientManager"/>
                    </globals>
                </component>

                <component id="volatility-feed" name="VolatilityFeed" file="elysian_core/connectors/VolatiltyFeed.py">
                    <description>Volatility data feed with Redis caching</description>
                </component>
            </components>
        </layer>

        <layer id="order-management" name="Order Management Layer" type="trading-execution">
            <description>Order placement, tracking, and portfolio management</description>
            <components>
                <component id="oms-core" name="OMS" file="elysian_core/oms/oms.py">
                    <class name="AbstractOMS" type="abstract">
                        <description>Abstract base class for order management systems</description>
                        <methods>
                            <method name="place_order" description="Abstract order placement"/>
                            <method name="cancel_order" description="Abstract order cancellation"/>
                            <method name="get_balance" description="Abstract balance query"/>
                        </methods>
                    </class>
                </component>

                <component id="order-tracker" name="OrderTracker" file="elysian_core/oms/order_tracker.py">
                    <class name="OrderTracker">
                        <description>Tracks order lifecycle and fill status</description>
                        <methods>
                            <method name="track_order" description="Monitor order execution"/>
                            <method name="get_status" description="Get order status"/>
                            <method name="fill_history" description="Get fill history"/>
                        </methods>
                    </class>
                </component>
            </components>
        </layer>

        <layer id="core-models" name="Core Models Layer" type="data-structures">
            <description>Core data structures and domain models</description>
            <components>
                <component id="market-data-models" name="MarketData" file="elysian_core/core/market_data.py">
                    <classes>
                        <class name="Kline">
                            <description>Candlestick data structure</description>
                            <attributes>
                                <attribute name="ticker" type="str"/>
                                <attribute name="interval" type="str"/>
                                <attribute name="start_time" type="datetime"/>
                                <attribute name="end_time" type="datetime"/>
                                <attribute name="open" type="float"/>
                                <attribute name="high" type="float"/>
                                <attribute name="low" type="float"/>
                                <attribute name="close" type="float"/>
                                <attribute name="volume" type="float"/>
                            </attributes>
                        </class>
                        <class name="OrderBook">
                            <description>Order book snapshot</description>
                            <attributes>
                                <attribute name="last_update_id" type="int"/>
                                <attribute name="last_timestamp" type="int"/>
                                <attribute name="ticker" type="str"/>
                                <attribute name="interval" type="str"/>
                                <attribute name="best_bid_price" type="float"/>
                                <attribute name="best_bid_amount" type="float"/>
                                <attribute name="best_ask_price" type="float"/>
                                <attribute name="best_ask_amount" type="float"/>
                                <attribute name="bid_orders" type="list"/>
                                <attribute name="ask_orders" type="list"/>
                            </attributes>
                        </class>
                    </classes>
                </component>

                <component id="order-models" name="Order" file="elysian_core/core/order.py">
                    <classes>
                        <class name="Order" type="abstract">
                            <description>Base order class</description>
                        </class>
                        <class name="LimitOrder" inherits="Order">
                            <description>Limit order implementation</description>
                        </class>
                        <class name="RangeOrder" inherits="Order">
                            <description>Range order implementation</description>
                        </class>
                    </classes>
                </component>

                <component id="enums" name="Enums" file="elysian_core/core/enums.py">
                    <enums>
                        <enum name="OrderStatus">
                            <values>
                                <value>OPEN</value>
                                <value>FILLED</value>
                                <value>CANCELLED</value>
                                <value>PARTIALLY_FILLED</value>
                                <value>PENDING</value>
                                <value>REJECTED</value>
                            </values>
                        </enum>
                        <enum name="Side">
                            <values>
                                <value>BUY</value>
                                <value>SELL</value>
                            </values>
                        </enum>
                        <enum name="TradeType">
                            <values>
                                <value>REAL</value>
                                <value>SIMULATED</value>
                            </values>
                        </enum>
                    </enums>
                </component>

                <component id="trade-models" name="Trade" file="elysian_core/core/trade.py">
                    <class name="Trade">
                        <description>Trade execution record</description>
                        <attributes>
                            <attribute name="datetime" type="datetime"/>
                            <attribute name="tx_digest" type="str"/>
                            <attribute name="symbol" type="str"/>
                            <attribute name="side" type="Side"/>
                            <attribute name="amount" type="float"/>
                            <attribute name="executed_qty" type="float"/>
                            <attribute name="price" type="float"/>
                            <attribute name="commission" type="float"/>
                            <attribute name="order_id" type="str"/>
                            <attribute name="status" type="OrderStatus"/>
                        </attributes>
                    </class>
                </component>

                <component id="portfolio-models" name="Portfolio" file="elysian_core/core/portfolio.py">
                    <class name="Portfolio">
                        <description>Portfolio state and position tracking</description>
                        <attributes>
                            <attribute name="balances" type="dict"/>
                            <attribute name="positions" type="dict"/>
                            <attribute name="pnl" type="float"/>
                        </attributes>
                    </class>
                </component>
            </components>
        </layer>

        <layer id="strategy" name="Strategy Layer" type="trading-logic">
            <description>Trading strategies and signal processing</description>
            <components>
                <component id="strategy-engine" name="StrategyEngine" file="elysian_core/strategy/strategy_engine.py">
                    <class name="StrategyEngine">
                        <description>Main strategy execution engine</description>
                        <methods>
                            <method name="on_event" description="Process market data events"/>
                            <method name="get_feed" description="Access data feeds"/>
                            <method name="get_price" description="Get current prices"/>
                            <method name="place_order" description="Execute orders via OMS"/>
                            <method name="cancel_order" description="Cancel orders via OMS"/>
                        </methods>
                        <attributes>
                            <attribute name="_feeds" type="dict" description="Active data feeds"/>
                            <attribute name="_exchange" type="object" description="Exchange client"/>
                        </attributes>
                    </class>
                </component>

                <component id="processor" name="Processor" file="elysian_core/strategy/processor.py">
                    <class name="Processor">
                        <description>Signal processing and event chaining</description>
                        <methods>
                            <method name="process" description="Process trading signals"/>
                        </methods>
                    </class>
                </component>
            </components>
        </layer>

        <layer id="market-maker" name="Market Maker Layer" type="market-making">
            <description>Market making algorithms and order management</description>
            <components>
                <component id="order-book-analysis" name="OrderBookAnalysis" file="elysian_core/market_maker/order_book.py">
                    <description>Order book analysis and spread calculations</description>
                    <methods>
                        <method name="calculate_spread" description="Calculate bid-ask spread"/>
                        <method name="extract_levels" description="Extract order book levels"/>
                    </methods>
                </component>

                <component id="order-management" name="OrderManagement" file="elysian_core/market_maker/order_management.py">
                    <description>Market maker order lifecycle management</description>
                    <methods>
                        <method name="create_range_order" description="Create range orders"/>
                        <method name="update_positions" description="Update position tracking"/>
                        <method name="manage_lifecycle" description="Manage order lifecycle"/>
                    </methods>
                </component>

                <component id="order-tracker-mm" name="OrderTrackerMM" file="elysian_core/market_maker/order_tracker.py">
                    <description>Market maker specific order tracking</description>
                    <methods>
                        <method name="track_mm_orders" description="Track market making orders"/>
                        <method name="monitor_fills" description="Monitor order fills"/>
                        <method name="adjust_levels" description="Adjust order levels"/>
                    </methods>
                </component>
            </components>
        </layer>

        <layer id="persistence" name="Persistence Layer" type="data-storage">
            <description>Data persistence and storage backends</description>
            <components>
                <component id="database-core" name="Database" file="elysian_core/db/database.py">
                    <description>Database connection and pooling</description>
                    <methods>
                        <method name="connect" description="Establish database connection"/>
                        <method name="execute" description="Execute database queries"/>
                    </methods>
                </component>

                <component id="models" name="Models" file="elysian_core/db/models.py">
                    <description>Peewee ORM models</description>
                    <classes>
                        <class name="BinanceTrade">
                            <description>Binance trade records</description>
                        </class>
                        <class name="CexTrade">
                            <description>CEX trade records</description>
                        </class>
                        <class name="OrderHistory">
                            <description>Order history records</description>
                        </class>
                        <class name="PortfolioState">
                            <description>Portfolio state snapshots</description>
                        </class>
                    </classes>
                </component>
            </components>
            <backends>
                <backend name="PostgreSQL" description="Primary relational database">
                    <purpose>Trade history, order records, portfolio state</purpose>
                </backend>
                <backend name="Redis" description="High-performance cache">
                    <purpose>Volatility cache, live order tracking, balance cache</purpose>
                </backend>
                <backend name="FileSystem" description="File-based storage">
                    <purpose>Logs, configuration, backtesting data</purpose>
                </backend>
            </backends>
        </layer>

        <layer id="utilities" name="Utilities Layer" type="supporting">
            <description>Supporting utilities and infrastructure</description>
            <components>
                <component id="configuration" name="Configuration" file="elysian_core/config/">
                    <files>
                        <file name="config.json" description="JSON configuration"/>
                        <file name="config.yaml" description="YAML configuration"/>
                    </files>
                </component>

                <component id="logging" name="Logger" file="elysian_core/utils/logger.py">
                    <description>Custom logging setup and configuration</description>
                </component>

                <component id="constants" name="Constants" file="elysian_core/utils/constants.py">
                    <description>System-wide constants and enumerations</description>
                </component>

                <component id="data-types" name="DataTypes" file="elysian_core/utils/data_types.py">
                    <description>Custom data type definitions</description>
                </component>

                <component id="utils" name="Utils" file="elysian_core/utils/utils.py">
                    <description>General utility functions</description>
                </component>
            </components>
        </layer>
    </layers>

    <!-- Data Flow Relationships -->
    <data-flows>
        <flow id="market-data-flow" from="market-data" to="strategy">
            <description>Real-time market data flows from exchanges to strategy engine</description>
            <path>
                <step>Exchange WebSocket → ClientManager → Feed → StrategyEngine.on_event()</step>
            </path>
        </flow>

        <flow id="order-flow" from="strategy" to="order-management">
            <description>Order signals flow from strategy to order management</description>
            <path>
                <step>StrategyEngine → Processor → OMS.place_order() → Exchange</step>
            </path>
        </flow>

        <flow id="execution-flow" from="order-management" to="persistence">
            <description>Trade execution data flows to persistence layer</description>
            <path>
                <step>Exchange → OrderTracker → Portfolio.update() → Database.save()</step>
            </path>
        </flow>

        <flow id="portfolio-flow" from="order-management" to="core-models">
            <description>Portfolio updates flow to core models</description>
            <path>
                <step>OrderTracker → Portfolio.update() → Core Models</step>
            </path>
        </flow>
    </data-flows>

    <!-- Component Dependencies -->
    <dependencies>
        <dependency from="strategy-runner" to="market-data" type="initialization"/>
        <dependency from="strategy-runner" to="order-management" type="orchestration"/>
        <dependency from="strategy-runner" to="strategy" type="execution"/>
        <dependency from="strategy-runner" to="market-maker" type="execution"/>
        <dependency from="strategy-runner" to="persistence" type="data-access"/>
        <dependency from="strategy-runner" to="utilities" type="configuration"/>

        <dependency from="market-data" to="core-models" type="data-structures"/>
        <dependency from="market-data" to="persistence" type="data-storage"/>
        <dependency from="market-data" to="utilities" type="logging"/>

        <dependency from="order-management" to="core-models" type="data-structures"/>
        <dependency from="order-management" to="market-data" type="price-data"/>
        <dependency from="order-management" to="persistence" type="data-storage"/>
        <dependency from="order-management" to="utilities" type="logging"/>

        <dependency from="strategy" to="market-data" type="market-data"/>
        <dependency from="strategy" to="order-management" type="order-execution"/>
        <dependency from="strategy" to="core-models" type="data-structures"/>
        <dependency from="strategy" to="utilities" type="logging"/>

        <dependency from="market-maker" to="market-data" type="market-data"/>
        <dependency from="market-maker" to="order-management" type="order-execution"/>
        <dependency from="market-maker" to="strategy" type="signal-processing"/>
        <dependency from="market-maker" to="core-models" type="data-structures"/>
        <dependency from="market-maker" to="utilities" type="logging"/>

        <dependency from="core-models" to="persistence" type="data-storage"/>
        <dependency from="core-models" to="utilities" type="logging"/>

        <dependency from="persistence" to="utilities" type="logging"/>
    </dependencies>

    <!-- External Interfaces -->
    <external-interfaces>
        <interface id="binance-api" name="Binance API" type="websocket-rest">
            <description>Binance exchange API for market data and trading</description>
            <endpoints>
                <endpoint url="wss://stream.binance.com:9443/ws" type="websocket"/>
                <endpoint url="https://api.binance.com/api/v3/" type="rest"/>
            </endpoints>
        </interface>

        <interface id="aster-api" name="Aster DEX API" type="websocket-rest">
            <description>Aster DEX API for market data and trading</description>
            <endpoints>
                <endpoint url="wss://sstream.asterdex.com/ws" type="websocket"/>
                <endpoint url="https://sapi.asterdex.com/api/v1/" type="rest"/>
            </endpoints>
        </interface>

        <interface id="postgresql" name="PostgreSQL" type="database">
            <description>Primary relational database for trade and order data</description>
            <purpose>Persistent storage of trading data</purpose>
        </interface>

        <interface id="redis" name="Redis" type="cache">
            <description>High-performance cache for volatile data</description>
            <purpose>Caching of market data and temporary state</purpose>
        </interface>

        <interface id="filesystem" name="File System" type="storage">
            <description>File-based storage for logs and configuration</description>
            <purpose>Persistence of logs, configuration, and backtesting data</purpose>
        </interface>
    </external-interfaces>

    <!-- System Characteristics -->
    <characteristics>
        <characteristic name="architecture-pattern" value="Layered Architecture"/>
        <characteristic name="concurrency-model" value="AsyncIO + ThreadPoolExecutor"/>
        <characteristic name="data-flow" value="Event-Driven"/>
        <characteristic name="multiplexing" value="WebSocket Multiplex Streams"/>
        <characteristic name="persistence" value="Multi-Backend (PostgreSQL + Redis + Files)"/>
        <characteristic name="exchange-support" value="Multi-Exchange (Binance + Aster DEX)"/>
        <characteristic name="scalability" value="Horizontal (Multiple Symbols per Connection)"/>
        <characteristic name="resilience" value="Auto-Reconnection + Error Handling"/>
    </characteristics>

    <!-- Deployment Considerations -->
    <deployment>
        <environment name="development">
            <requirements>
                <requirement>Python 3.8+</requirement>
                <requirement>PostgreSQL</requirement>
                <requirement>Redis</requirement>
            </requirements>
        </environment>
        <environment name="production">
            <requirements>
                <requirement>Python 3.8+</requirement>
                <requirement>PostgreSQL Cluster</requirement>
                <requirement>Redis Cluster</requirement>
                <requirement>Docker/Kubernetes</requirement>
            </requirements>
        </environment>
    </deployment>
</architecture-diagram></content>
